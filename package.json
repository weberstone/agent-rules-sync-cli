{
  "name": "agent-context-sync-cli",
  "version": "0.1.0",
  "description": "Centralized AI agent rules manager — interactive CLI to generate per-project rule files",
  "type": "module",
  "license": "MIT",
  "author": "",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "agent-rules-sync": "./dist/index.js"
  },
  "files": [
    "dist/",
    "context/"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
