# Path to the context directory (absolute or relative to the project root).
# Must contain a "rules/" subdirectory; "skills/" and "projects/" are optional.
#
# Supports:
#   - Simple values:     AGENT_CONTEXT_DIR=context2
#   - Quoted values:     AGENT_CONTEXT_DIR="./my context"
#   - Inline comments:   AGENT_CONTEXT_DIR=context2  # my note
#
# Default: auto-discovered from the package installation ("context/")
AGENT_CONTEXT_DIR=context